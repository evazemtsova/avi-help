ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ADMIN_TOKEN=придумай-длинную-строку

# Sprint 5 Блок 5 — reranker config (optional, defaults в коде):
# USE_RERANKER=true                              # default true
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3          # default
# RERANKER_CANDIDATES=20                          # default
# RETRIEVAL_THRESHOLD=0.55                        # default 0.55
#
# На Railway рекомендуется HF_HOME → persistent volume чтобы модель reranker'а
# (~600 MB) загружалась с HuggingFace только один раз, потом из volume:
# HF_HOME=/data/.cache/huggingface